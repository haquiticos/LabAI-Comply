# Endpoint: GET /audit/usage
# ===================================================================
@app.get("/audit/usage")
async def audit_usage(
    from_date: Optional[str] = Query(None),
    to_date: Optional[str] = Query(None)
):
    records = []
    try:
        with open(AUDIT_LOG_PATH, "r") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue

                ts = entry.get("timestamp", "")
                try:
                    entry_date = datetime.fromisoformat(ts).date()
                except (ValueError, TypeError):
                    continue

                if from_date:
                    try:
                        if entry_date < date.fromisoformat(from_date):
                            continue
                    except ValueError:
                        pass
                if to_date:
                    try:
                        if entry_date > date.fromisoformat(to_date):
                            continue
                    except ValueError:
                        pass

                records.append(entry)
    except FileNotFoundError:
        pass
    except Exception as e:
        logger.error(f"Error reading audit log: {e}")

    return JSONResponse(content={"records": records, "count": len(records)})


# ===================================================================
# Endpoint: GET /audit/report
# ===================================================================
@app.get("/audit/report")
async def audit_report(
    format: str = Query("csv"),
    from_date: Optional[str] = Query(None),
    to_date: Optional[str] = Query(None)
):
    # Aggregate records
    aggregates: dict[tuple, dict] = {}
    try:
        with open(AUDIT_LOG_PATH, "r") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue

                ts = entry.get("timestamp", "")
                try:
                    entry_date = datetime.fromisoformat(ts).date()
                except (ValueError, TypeError):
                    continue

                if from_date:
                    try:
                        if entry_date < date.fromisoformat(from_date):
                            continue
                    except ValueError:
                        pass
                if to_date:
                    try:
                        if entry_date > date.fromisoformat(to_date):
                            continue
                    except ValueError:
                        pass

                date_str = entry_date.strftime("%d/%m/%Y")
                model = entry.get("model_used", entry.get("model", "unknown"))
                provider = entry.get("provider", "unknown")
                finalidade = entry.get("finalidade", "nao especificada")
                fase = entry.get("fase_pesquisa", "nao especificada")

                key = (date_str, model, provider, finalidade, fase)
                if key not in aggregates:
                    aggregates[key] = {"interactions": 0, "tokens_approx": 0}
                aggregates[key]["interactions"] += 1
                aggregates[key]["tokens_approx"] += (
                    entry.get("tokens_in", 0) + entry.get("tokens_out", 0)
                )
    except FileNotFoundError:
        pass
    except Exception as e:
        logger.error(f"Error reading audit log: {e}")

    model_display_names = {
        "qwen2.5:14b-instruct-q4_K_M": "Qwen2.5 14B (Ollama local)",
        "gpt-4": "GPT-4 (OpenAI)",
        "gpt-3.5-turbo": "GPT-3.5 Turbo (OpenAI)",
        "glm-5.2": "GLM-5.2 (z.ai)",
        "glm-4.7": "GLM-4.7 (z.ai)",
        "glm-4.6": "GLM-4.6 (z.ai)",
        "glm-4.5": "GLM-4.5 (z.ai)",
        "glm-4-plus": "GLM-4 Plus (z.ai)"
    }

    # ----- CSV format -----
    if format == "csv":
        output = io.StringIO()
        writer = csv.writer(output)
        writer.writerow([
            "Data", "Ferramenta", "Finalidade",
            "Fase da Pesquisa", "Interacoes", "Tokens (aprox.)"
        ])

        for (d, model, provider, finalidade, fase), agg in sorted(aggregates.items()):
            display_name = model_display_names.get(
                model, f"{model} ({provider})"
            )
            writer.writerow([
                d,
                display_name,
                finalidade,
                fase,
                agg["interactions"],
                agg["tokens_approx"]
            ])

        output.seek(0)
        return Response(
            content=output.getvalue(),
            media_type="text/csv",
            headers={"Content-Disposition": "attachment; filename=audit_report.csv"}
        )

    # ----- PDF format -----
    if format == "pdf":
        pdf = FPDF()
        pdf.add_page()

        # Title
        pdf.set_font("Helvetica", "B", 16)
        pdf.cell(
            0, 10,
            "Relatorio de Uso de IA - LabAI-Comply",
            new_x="LMARGIN", new_y="NEXT", align="C"
        )
        pdf.ln(5)

        # Period subtitle
        if from_date or to_date:
            period_str = f"Periodo: {from_date or 'inicio'} ate {to_date or 'agora'}"
        else:
            period_str = "Periodo: todos os registros"
        pdf.set_font("Helvetica", "", 11)
        pdf.cell(0, 8, period_str, new_x="LMARGIN", new_y="NEXT", align="C")
        pdf.ln(5)

        # Table header
        col_widths = [25, 50, 45, 40, 15, 20]
        headers_pdf = ["Data", "Ferramenta", "Finalidade", "Fase Pesquisa", "Int.", "Tokens"]

        pdf.set_font("Helvetica", "B", 8)
        pdf.set_fill_color(200, 200, 200)
        for i, h in enumerate(headers_pdf):
            pdf.cell(col_widths[i], 7, h, border=1, fill=True)
        pdf.ln()

        # Table rows
        pdf.set_font("Helvetica", "", 7)

        pdf_model_names = {
            "qwen2.5:14b-instruct-q4_K_M": "Qwen2.5 14B (Ollama)",
            "gpt-4": "GPT-4 (OpenAI)",
            "gpt-3.5-turbo": "GPT-3.5 (OpenAI)",
            "glm-5.2": "GLM-5.2 (z.ai)",
            "glm-4.7": "GLM-4.7 (z.ai)",
            "glm-4.6": "GLM-4.6 (z.ai)",
            "glm-4.5": "GLM-4.5 (z.ai)",
            "glm-4-plus": "GLM-4 Plus (z.ai)"
        }

        for (d, model, provider, finalidade, fase), agg in sorted(aggregates.items()):
            display_name = pdf_model_names.get(model, model)
            row = [
                d,
                display_name[:30],
                finalidade[:25],
                fase[:22],
                str(agg["interactions"]),
                str(agg["tokens_approx"])
            ]
            for i, val in enumerate(row):
                pdf.cell(col_widths[i], 6, val, border=1)
            pdf.ln()

        # Footer
        pdf.ln(10)
        pdf.set_font("Helvetica", "I", 8)
        pdf.cell(
            0, 5,
            f"Gerado em: {datetime.now().strftime('%d/%m/%Y %H:%M:%S')}",
            new_x="LMARGIN", new_y="NEXT", align="C"
        )

        pdf_content = bytes(pdf.output())
        return Response(
            content=pdf_content,
            media_type="application/pdf",
            headers={"Content-Disposition": "attachment; filename=audit_report.pdf"}
        )

