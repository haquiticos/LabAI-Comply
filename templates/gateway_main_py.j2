# Endpoint: POST /cloud/v1/chat/completions
# ===================================================================
@app.post("/cloud/v1/chat/completions")
async def cloud_chat_completions(request: Request):
    ws = identify_workspace(request)
    user_email = request.headers.get("X-User-Email", "unknown")
    request_id = str(uuid.uuid4())
    start_time = datetime.utcnow()

    body = await request.json()
    is_stream = body.get("stream", False)

    # Extract text from messages for PII detection
    messages_text = " ".join(
        m.get("content", "") for m in body.get("messages", [])
    )

    # PII detection (fail-open)
    entities, _, pseudonym_map = await detect_pii(messages_text)
    pii_detected = len(entities) > 0
    pii_types = list(set(e["entity_type"] for e in entities)) if entities else []

    # If PII was found, anonymize each message using the pseudonym map
    if pii_detected and pseudonym_map:
        sorted_pseudonyms = sorted(
            pseudonym_map.items(), key=lambda x: len(x[1]), reverse=True
        )
        for msg in body.get("messages", []):
            content = msg.get("content", "")
            if content:
                for pseudonym, original in sorted_pseudonyms:
                    content = content.replace(original, pseudonym)
                msg["content"] = content

    forward_body = json.dumps(body)

    try:
        headers = {
            "Content-Type": "application/json",
            "Authorization": f"Bearer {OPENAI_API_KEY}"
        }

        async with httpx.AsyncClient(timeout=REQUEST_TIMEOUT) as client:
            upstream_req = client.build_request(
                "POST",
                f"{OPENAI_BASE_URL}/chat/completions",
                content=forward_body,
                headers=headers
            )
            upstream_resp = await client.send(upstream_req, stream=is_stream)

            if is_stream:
                if pii_detected:
                    async def generate_pii():
                        try:
                            async for chunk in stream_with_pii_restoration(
                                upstream_resp, pseudonym_map
                            ):
                                yield chunk
                        finally:
                            await upstream_resp.aclose()

                    async def on_stream_complete_pii():
                        await write_audit({
                            "request_id": request_id,
                            "timestamp": start_time.isoformat(),
                            "workspace": ws["name"],
                            "user": user_email,
                            "action": "chat_completion",
                            "provider": "openai",
                            "model_used": body.get("model", "unknown"),
                            "stream": True,
                            "tokens_in": 0,
                            "tokens_out": 0,
                            "latency_ms": int((datetime.utcnow() - start_time).total_seconds() * 1000),
                            "pii_detected": True,
                            "pii_types": pii_types,
                            "pii_count": len(entities),
                            "finalidade": ws.get("finalidade", "nao especificada"),
                            "fase_pesquisa": ws.get("fase_pesquisa", "nao especificada")
                        })

                    return StreamingResponse(
                        generate_pii(),
                        media_type="text/event-stream",
                        background=BackgroundTask(on_stream_complete_pii)
                    )
                else:
                    async def generate():
                        try:
                            async for chunk in upstream_resp.aiter_bytes():
                                yield chunk
                        finally:
                            await upstream_resp.aclose()

                    async def on_stream_complete():
                        await write_audit({
                            "request_id": request_id,
                            "timestamp": start_time.isoformat(),
                            "workspace": ws["name"],
                            "user": user_email,
                            "action": "chat_completion",
                            "provider": "openai",
                            "model_used": body.get("model", "unknown"),
                            "stream": True,
                            "tokens_in": 0,
                            "tokens_out": 0,
                            "latency_ms": int((datetime.utcnow() - start_time).total_seconds() * 1000),
                            "pii_detected": False,
                            "pii_types": [],
                            "pii_count": 0,
                            "finalidade": ws.get("finalidade", "nao especificada"),
                            "fase_pesquisa": ws.get("fase_pesquisa", "nao especificada")
                        })

                    return StreamingResponse(
                        generate(),
                        media_type="text/event-stream",
                        background=BackgroundTask(on_stream_complete)
                    )
            else:
                duration_ms = int((datetime.utcnow() - start_time).total_seconds() * 1000)
                response_text = upstream_resp.text

                if pii_detected:
                    response_text = restore_pseudonyms(response_text, pseudonym_map)

                # Extract token counts from upstream response
                tokens_in = 0
                tokens_out = 0
                try:
                    resp_json = json.loads(response_text)
                    usage = resp_json.get("usage", {})
                    tokens_in = usage.get("prompt_tokens", 0)
                    tokens_out = usage.get("completion_tokens", 0)
                except (json.JSONDecodeError, AttributeError):
                    pass

                await write_audit({
                    "request_id": request_id,
                    "timestamp": start_time.isoformat(),
                    "workspace": ws["name"],
                    "user": user_email,
                    "action": "chat_completion",
                    "provider": "openai",
                    "model_used": body.get("model", "unknown"),
                    "stream": False,
                    "tokens_in": tokens_in,
                    "tokens_out": tokens_out,
                    "latency_ms": duration_ms,
                    "pii_detected": pii_detected,
                    "pii_types": pii_types,
                    "pii_count": len(entities),
                    "status_code": upstream_resp.status_code,
                    "finalidade": ws.get("finalidade", "nao especificada"),
                    "fase_pesquisa": ws.get("fase_pesquisa", "nao especificada")
                })

                return Response(
                    content=response_text,
                    status_code=upstream_resp.status_code,
                    media_type="application/json"
                )
    except Exception as e:
        logger.error(f"Cloud completion error: {e}")
        raise HTTPException(status_code=502, detail=str(e))


