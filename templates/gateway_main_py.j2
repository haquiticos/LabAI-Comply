# Endpoint: GET /health
# ===================================================================
@app.get("/health")
async def health():
    checks = {}
    overall = "healthy"

    # Check Ollama
    try:
        async with httpx.AsyncClient(timeout=5.0) as client:
            resp = await client.get("http://ollama:11434/api/tags")
            checks["ollama"] = "up" if resp.status_code == 200 else "degraded"
    except Exception:
        checks["ollama"] = "down"
        overall = "degraded"

    # Check Presidio Analyzer
    try:
        async with httpx.AsyncClient(timeout=5.0) as client:
            resp = await client.get("http://presidio-analyzer:3000/health")
            checks["presidio_analyzer"] = "up" if resp.status_code == 200 else "degraded"
    except Exception:
        checks["presidio_analyzer"] = "down"

    # Check Presidio Anonymizer
    try:
        async with httpx.AsyncClient(timeout=5.0) as client:
            resp = await client.get("http://presidio-anonymizer:5001/health")
            checks["presidio_anonymizer"] = "up" if resp.status_code == 200 else "degraded"
    except Exception:
        checks["presidio_anonymizer"] = "down"

    status_code = 200 if overall == "healthy" else 503
    return JSONResponse(
        content={"status": overall, "checks": checks},
        status_code=status_code
    )


