# Endpoint: POST /local/v1/chat/completions
# ===================================================================
@app.post("/local/v1/chat/completions")
async def local_chat_completions(request: Request):
    ws = identify_workspace(request)
    user_email = request.headers.get("X-User-Email", "unknown")
    request_id = str(uuid.uuid4())
    start_time = datetime.utcnow()

    body = await request.json()
    is_stream = body.get("stream", False)
    forward_body = json.dumps(body)

    try:
        async with httpx.AsyncClient(timeout=REQUEST_TIMEOUT) as client:
            upstream_req = client.build_request(
                "POST",
                "http://ollama:11434/v1/chat/completions",
                content=forward_body,
                headers={"Content-Type": "application/json"}
            )
            upstream_resp = await client.send(upstream_req, stream=is_stream)

            if is_stream:
                async def generate():
                    try:
                        async for chunk in upstream_resp.aiter_bytes():
                            yield chunk
                    finally:
                        await upstream_resp.aclose()

                async def on_stream_complete():
                    await write_audit({
                        "request_id": request_id,
                        "timestamp": start_time.isoformat(),
                        "workspace": ws["name"],
                        "user": user_email,
                        "action": "chat_completion",
                        "provider": "ollama",
                        "model_used": ws.get("model", OLLAMA_MODEL),
                        "stream": True,
                        "tokens_in": 0,
                        "tokens_out": 0,
                        "latency_ms": int((datetime.utcnow() - start_time).total_seconds() * 1000),
                        "pii_detected": False,
                        "pii_types": [],
                        "pii_count": 0,
                        "finalidade": ws.get("finalidade", "nao especificada"),
                        "fase_pesquisa": ws.get("fase_pesquisa", "nao especificada")
                    })

                return StreamingResponse(
                    generate(),
                    media_type="text/event-stream",
                    background=BackgroundTask(on_stream_complete)
                )
            else:
                duration_ms = int((datetime.utcnow() - start_time).total_seconds() * 1000)
                response_content = upstream_resp.content

                # Extract token counts from upstream response
                tokens_in = 0
                tokens_out = 0
                try:
                    resp_json = json.loads(response_content)
                    usage = resp_json.get("usage", {})
                    tokens_in = usage.get("prompt_tokens", 0)
                    tokens_out = usage.get("completion_tokens", 0)
                except (json.JSONDecodeError, AttributeError):
                    pass

                await write_audit({
                    "request_id": request_id,
                    "timestamp": start_time.isoformat(),
                    "workspace": ws["name"],
                    "user": user_email,
                    "action": "chat_completion",
                    "provider": "ollama",
                    "model_used": ws.get("model", OLLAMA_MODEL),
                    "stream": False,
                    "tokens_in": tokens_in,
                    "tokens_out": tokens_out,
                    "latency_ms": duration_ms,
                    "pii_detected": False,
                    "pii_types": [],
                    "pii_count": 0,
                    "status_code": upstream_resp.status_code,
                    "finalidade": ws.get("finalidade", "nao especificada"),
                    "fase_pesquisa": ws.get("fase_pesquisa", "nao especificada")
                })

                return Response(
                    content=response_content,
                    status_code=upstream_resp.status_code,
                    media_type="application/json"
                )
    except Exception as e:
        logger.error(f"Local completion error: {e}")
        raise HTTPException(status_code=502, detail=str(e))


