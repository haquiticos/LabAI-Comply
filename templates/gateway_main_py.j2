# ---------------------------------------------------------------------------
# Middleware: request body size limit
# ---------------------------------------------------------------------------
@app.middleware("http")
async def limit_body_size(request: Request, call_next):
    max_bytes = MAX_BODY_MB * 1024 * 1024
    content_length = request.headers.get("content-length")
    if content_length and int(content_length) > max_bytes:
        return JSONResponse(
            status_code=413,
            content={"detail": f"Request body too large. Maximum {MAX_BODY_MB}MB allowed."}
        )
    response = await call_next(request)
    return response


# ---------------------------------------------------------------------------
# Workspace registry
# ---------------------------------------------------------------------------
workspace_registry = {}
api_key_to_workspace = {}


def load_workspace_registry():
    global workspace_registry, api_key_to_workspace
    try:
        with open(WORKSPACE_REGISTRY_PATH, "r") as f:
            workspace_registry = yaml.safe_load(f) or {}
        for ws_name, ws_config in workspace_registry.items():
            api_key = ws_config.get("api_key", "")
            if api_key:
                api_key_to_workspace[api_key] = {"name": ws_name, **ws_config}
        logger.info(f"Loaded {len(workspace_registry)} workspaces from registry")
    except Exception as e:
        logger.error(f"Failed to load workspace registry: {e}")


@app.on_event("startup")
async def startup():
    load_workspace_registry()


# ---------------------------------------------------------------------------
# Audit logging
# ---------------------------------------------------------------------------
audit_lock = asyncio.Lock()


async def write_audit(entry: dict):
    async with audit_lock:
        try:
            with open(AUDIT_LOG_PATH, "a") as f:
                f.write(json.dumps(entry, ensure_ascii=False) + "\n")
        except Exception as e:
            logger.error(f"Failed to write audit log: {e}")


# ---------------------------------------------------------------------------
# Workspace identification helper
# ---------------------------------------------------------------------------
def identify_workspace(request: Request) -> dict:
    auth_header = request.headers.get("Authorization", "")
    api_key = ""
    if auth_header.startswith("Bearer"):
        api_key = auth_header.replace("Bearer ", "").strip()
    ws = api_key_to_workspace.get(api_key)
    if ws:
        return ws
    return {
        "name": "unknown",
        "finalidade": "nao especificada",
        "fase_pesquisa": "nao especificada",
        "provider": "unknown",
        "model": OLLAMA_MODEL,
        "path": "/local"
    }


# ---------------------------------------------------------------------------
# PII Detection (with fail-open)
# ---------------------------------------------------------------------------
async def detect_pii(text: str, language: str = "pt") -> tuple[list, str, dict]:
    """
    Detect and anonymise PII in *text*.

    Returns
    -------
    (entities, anonymized_text, pseudonym_map)
        Fail-open: if Presidio is unavailable, returns ([], text, {}).
    """
    try:
        async with httpx.AsyncClient(timeout=10.0) as client:
            # Step 1 — analyse
            analyze_resp = await client.post(
                "http://presidio-analyzer:3000/analyze",
                json={
                    "text": text,
                    "language": language,
                    "score_threshold": {% endraw %}{{ presidio_score_threshold | default(0.5) }}{% raw %}
                }
            )
            analyze_resp.raise_for_status()
            entities = analyze_resp.json()

            if not entities:
                return [], text, {}

            # Step 2 — build pseudonym mapping (ascending by start position)
            entity_counter: dict[str, int] = {}
            pseudonym_map: dict[str, str] = {}
            replacements: list[tuple[int, int, str]] = []

            for entity in sorted(entities, key=lambda e: e["start"]):
                etype = entity["entity_type"]
                start = entity["start"]
                end = entity["end"]
                entity_counter[etype] = entity_counter.get(etype, 0) + 1
                pseudonym = f"<{etype}_{entity_counter[etype]}>"
                original_text = text[start:end]
                pseudonym_map[pseudonym] = original_text
                replacements.append((start, end, pseudonym))

            # Step 3 — replace from end to start (preserves earlier positions)
            anonymized = text
            for start, end, pseudonym in reversed(replacements):
                anonymized = anonymized[:start] + pseudonym + anonymized[end:]

            return entities, anonymized, pseudonym_map

    except Exception as e:
        logger.warning(f"PII detection failed (fail-open): {e}")
        return [], text, {}


# ---------------------------------------------------------------------------
# Pseudonym restoration
# ---------------------------------------------------------------------------
def restore_pseudonyms(text: str, mapping: dict) -> str:
    """Replace pseudonym tokens back with original values."""
    for pseudonym, original in mapping.items():
        text = text.replace(pseudonym, original)
    return text


# ---------------------------------------------------------------------------
# Streaming helper with PII restoration
# ---------------------------------------------------------------------------
async def stream_with_pii_restoration(upstream_response, pseudonym_map: dict, timeout: float = 5.0):
    """Stream SSE chunks, buffering partial pseudonym tokens for restoration."""
    buffer = ""
    pseudonym_pattern = re.compile(r"<[A-Z_]+_\d+>")
    partial_pattern = re.compile(r"<[A-Z_]*_?\d*$")

    async for chunk in upstream_response.aiter_bytes():
        text = chunk.decode("utf-8", errors="replace")
        buffer += text

        # Restore any complete pseudonyms already in the buffer
        buffer = pseudonym_pattern.sub(
            lambda m: pseudonym_map.get(m.group(), m.group()), buffer
        )

        # Check whether a partial pseudonym sits at the end of the buffer
        partial_match = partial_pattern.search(buffer)
        if partial_match and partial_match.end() == len(buffer):
            safe_part = buffer[:partial_match.start()]
            buffer = buffer[partial_match.start():]
            if safe_part:
                yield safe_part.encode("utf-8")
        else:
            if buffer:
                yield buffer.encode("utf-8")
                buffer = ""

    # Flush whatever remains
    if buffer:
        buffer = pseudonym_pattern.sub(
            lambda m: pseudonym_map.get(m.group(), m.group()), buffer
        )
        yield buffer.encode("utf-8")


